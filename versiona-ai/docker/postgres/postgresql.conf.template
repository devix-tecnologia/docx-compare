# =============================================================================
# PostgreSQL 16 - Configuração gerada via ENV vars pelo entrypoint
# Template: envsubst substitui ${PG_*} pelas variáveis de ambiente
# =============================================================================

# ---------------------------------------------------------------------------
# Conexões
# ---------------------------------------------------------------------------
max_connections = ${PG_MAX_CONNECTIONS}
superuser_reserved_connections = ${PG_SUPERUSER_RESERVED}

# ---------------------------------------------------------------------------
# Memória
# ---------------------------------------------------------------------------
shared_buffers = ${PG_SHARED_BUFFERS}
work_mem = ${PG_WORK_MEM}
maintenance_work_mem = ${PG_MAINTENANCE_WORK_MEM}
effective_cache_size = ${PG_EFFECTIVE_CACHE_SIZE}
huge_pages = ${PG_HUGE_PAGES}

# ---------------------------------------------------------------------------
# Write-Ahead Logging (WAL)
# ---------------------------------------------------------------------------
wal_level = ${PG_WAL_LEVEL}
max_wal_size = ${PG_MAX_WAL_SIZE}
min_wal_size = ${PG_MIN_WAL_SIZE}
checkpoint_completion_target = ${PG_CHECKPOINT_COMPLETION}
wal_buffers = ${PG_WAL_BUFFERS}
wal_compression = ${PG_WAL_COMPRESSION}

# ---------------------------------------------------------------------------
# Planejador de consultas
# ---------------------------------------------------------------------------
random_page_cost = ${PG_RANDOM_PAGE_COST}
effective_io_concurrency = ${PG_EFFECTIVE_IO_CONCURRENCY}
seq_page_cost = ${PG_SEQ_PAGE_COST}

# ---------------------------------------------------------------------------
# Paralelismo
# ---------------------------------------------------------------------------
max_parallel_workers_per_gather = ${PG_MAX_PARALLEL_WORKERS_GATHER}
max_parallel_workers = ${PG_MAX_PARALLEL_WORKERS}
max_parallel_maintenance_workers = ${PG_MAX_PARALLEL_MAINTENANCE}

# ---------------------------------------------------------------------------
# Otimizações de consulta
# ---------------------------------------------------------------------------
default_statistics_target = ${PG_DEFAULT_STATISTICS_TARGET}
jit = ${PG_JIT}

# ---------------------------------------------------------------------------
# pg_stat_statements (shared_preload_libraries via CMD)
# ---------------------------------------------------------------------------
pg_stat_statements.max = ${PG_STAT_STATEMENTS_MAX}
pg_stat_statements.track = ${PG_STAT_STATEMENTS_TRACK}

# ---------------------------------------------------------------------------
# Locale e Encoding
# ---------------------------------------------------------------------------
datestyle = 'iso, dmy'
timezone = 'America/Sao_Paulo'
lc_messages = 'pt_BR.UTF-8'
lc_monetary = 'pt_BR.UTF-8'
lc_numeric = 'pt_BR.UTF-8'
lc_time = 'pt_BR.UTF-8'

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
log_destination = 'stderr'
logging_collector = on
log_directory = 'pg_log'
log_filename = 'postgresql-%Y-%m-%d_%H%M%S.log'
log_rotation_age = 1d
log_rotation_size = 100MB
log_min_duration_statement = ${PG_LOG_MIN_DURATION_STATEMENT}
log_checkpoints = ${PG_LOG_CHECKPOINTS}
log_connections = ${PG_LOG_CONNECTIONS}
log_disconnections = ${PG_LOG_DISCONNECTIONS}
log_lock_waits = ${PG_LOG_LOCK_WAITS}
log_temp_files = 0
log_autovacuum_min_duration = 0
log_line_prefix = '%m [%p] %q%u@%d '

# ---------------------------------------------------------------------------
# Configurações de rede
# ---------------------------------------------------------------------------
listen_addresses = '${PG_LISTEN_ADDRESSES}'
max_prepared_transactions = 0
ssl = ${PG_SSL}

# ---------------------------------------------------------------------------
# Autovacuum
# ---------------------------------------------------------------------------
autovacuum = ${PG_AUTOVACUUM}
autovacuum_max_workers = ${PG_AUTOVACUUM_MAX_WORKERS}
autovacuum_naptime = ${PG_AUTOVACUUM_NAPTIME}
autovacuum_vacuum_threshold = ${PG_AUTOVACUUM_VACUUM_THRESHOLD}
autovacuum_analyze_threshold = ${PG_AUTOVACUUM_ANALYZE_THRESHOLD}
autovacuum_vacuum_scale_factor = ${PG_AUTOVACUUM_VACUUM_SCALE_FACTOR}
autovacuum_analyze_scale_factor = ${PG_AUTOVACUUM_ANALYZE_SCALE_FACTOR}
autovacuum_vacuum_cost_delay = ${PG_AUTOVACUUM_VACUUM_COST_DELAY}
autovacuum_vacuum_cost_limit = ${PG_AUTOVACUUM_VACUUM_COST_LIMIT}

# ---------------------------------------------------------------------------
# Replicação
# ---------------------------------------------------------------------------
max_wal_senders = ${PG_MAX_WAL_SENDERS}
wal_keep_size = ${PG_WAL_KEEP_SIZE}
max_replication_slots = ${PG_MAX_REPLICATION_SLOTS}
hot_standby = ${PG_HOT_STANDBY}
hot_standby_feedback = ${PG_HOT_STANDBY_FEEDBACK}
