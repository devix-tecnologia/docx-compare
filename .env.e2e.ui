# =================================================================
# Variáveis de Ambiente para Testes E2E UI
# =================================================================
# Este arquivo é usado como fallback se variáveis não forem definidas
# no docker-compose. Docker Compose tem prioridade (override=False).

# Directus
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@test.local
DIRECTUS_ADMIN_PASSWORD=TestPassword123!
DIRECTUS_TOKEN=test-token-will-be-created-after-setup

# API Versiona
API_URL=http://localhost:8001

# PostgreSQL
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus_test

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_TIMEOUT=30000

# Configuração geral
E2E_UI_TIMEOUT=60
PYTHONUNBUFFERED=1
