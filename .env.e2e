# Configuração de testes E2E
# Copie para .env.e2e e ajuste conforme necessário

# URL base da API a testar
E2E_BASE_URL=http://localhost:8001

# Timeout padrão para requisições (segundos)
E2E_TIMEOUT=30

# Permitir execução em produção (CUIDADO!)
E2E_ALLOW_PRODUCTION=false

# Configurações do Directus (herdadas do .env principal)
# DIRECTUS_BASE_URL=https://contract.devix.co
# DIRECTUS_TOKEN=seu-token-aqui
