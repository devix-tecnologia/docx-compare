 'b1cc1429-0d60-46f8-8b11-ac834eb8f3c9', 'cb87d66d-e37b-4d5d-9380-f49c543c3a0c', 'fe12176f-cf5d-4099-9a0f-3a714f13f2c7']}]}, {'id': '963061cf-60ce-46c5-a8cb-3e3d694e29b3', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:38.930Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '23.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_22_linha_17_pos_550', 'caminho_tag_fim': 'modificacao_22_linha_17_pos_559', 'conteudo': 'Qualquer das PARTES poderá rescindir o presente CONTRATO, mediante\n    simples aviso escrito à outra PARTE, sem necessidade de procedimento\n    judicial ou extrajudicial, nos seguintes casos:', 'posicao_inicio_texto': 145019, 'posicao_fim_texto': 145218, 'clausulas': [{'id': 'b22fe148-9872-47b5-a4cc-e79290e288f9', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T08:03:26.763Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:38.940Z', 'conteudo': 'Qualquer das PARTES poderá rescindir o presente CONTRATO, mediante simples aviso escrito à outra PARTE, sem necessidade de procedimento judicial ou extrajudicial, nos seguintes casos:', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '23.2', 'objetivo': 'Estabelecer que qualquer das partes pode rescindir o contrato por meio de aviso escrito, sem necessidade de ação judicial, em algumas hipóteses.', 'nome': 'Cláusula 23ª - 23.2', 'tag': '963061cf-60ce-46c5-a8cb-3e3d694e29b3', 'referencias': ['69e14076-8812-496b-9ada-c41d381dea81', 'aa738121-b371-4820-b8e7-805312f038e6', 'ce9c38f5-9acf-445d-99fd-6bba1c20c97b', 'dea70379-3336-4794-b986-438be204bb9e', 'e0c442b5-2abe-4997-bd53-53ec3ea93c71', 'f885663b-ea93-42cb-ae84-74605b3f64dd']}]}, {'id': 'de34bb77-38d0-41ad-8433-de280afcff93', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:38.980Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '14.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_8_linha_18_pos_615', 'caminho_tag_fim': 'modificacao_8_linha_18_pos_624', 'conteudo': 'As apólices contratadas pela CONTRATADA deverão permanecer\n    suficientes para a cobertura dos riscos assumidos neste CONTRATO\n    durante toda a vigência contratual.', 'posicao_inicio_texto': 119797, 'posicao_fim_texto': 119972, 'clausulas': [{'id': 'ed126f90-478d-4098-b1b7-38bce731ba1b', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T02:54:08.491Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.008Z', 'conteudo': 'As apólices contratadas pela CONTRATADA deverão permanecer suficientes para a cobertura dos riscos 2026-05-20T18:31:43.417608973Z assumidos neste CONTRATO durante toda a vigência contratual.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '14.2', 'objetivo': 'Garantir que os seguros contratados pela contratada cubram adequadamente os riscos do contrato durante todo o período de sua vigência.', 'nome': 'Cláusula 14ª - 14.2', 'tag': 'de34bb77-38d0-41ad-8433-de280afcff93', 'referencias': ['043b755a-554c-41d6-b092-f22e71da2cc0', '2ec3d1fc-e2a9-4db2-9c67-d3d3a0fe1390', '317cee0a-2406-4a72-aba2-738d63b72d35']}]}, {'id': '9676b8e5-564b-453d-bd5e-0096d4e1127b', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.153Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '24.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_23_linha_19_pos_627', 'caminho_tag_fim': 'modificacao_23_linha_19_pos_636', 'conteudo': 'Não sendo possível a solução, por meio de negociação direta, fica\n    desde já convencionado, de forma irrenunciável, que, quaisquer\n    controvérsias oriundas deste CONTRATO, serão definitivamente\n    resolvidas por meio de arbitragem, nos termos da Lei nº 9.307, de\n    23/09/1996, de acordo com as regras da Câmara de Arbitragem\n    Empresarial Brasil (CAMARB).', 'posicao_inicio_texto': 153269, 'posicao_fim_texto': 153641, 'clausulas': [{'id': '6d19a7b0-c941-4b41-b5f6-bbe35992df95', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T09:58:39.441Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.181Z', 'conteudo': 'Não sendo possível a solução, por meio de negociação direta, fica desde já convencionado, de forma irrenunciável, que, quaisquer controvérsias oriundas deste CONTRATO, serão definitivamente resolvidas por meio de arbitragem, nos termos da Lei nº 9.307, de 23/09/1996, de acordo com as regras da Câmara de Arbitragem Empresarial Brasil (CAMARB).', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '24.2', 'objetivo': 'Determinar que, se a negociação direta não resolver o conflito, qualquer disputa será resolvida de forma definitiva por arbitragem, seguindo as regras da CAMARB, conforme a Lei de Arbitragem brasileira.', 'nome': 'Cláusula 24ª - 24.2', 'tag': '9676b8e5-564b-453d-bd5e-0096d4e1127b', 'referencias': ['5da7c784-e06b-49c5-a9f0-6c80ca59ea45', 'be9cbf91-0202-40de-a6df-8707f35a4288', 'cdcb547e-8a78-4e19-bb47-bdedf35faebe', 'eb862da9-9061-4803-9aae-39c9851ad882']}]}, {'id': '739033a9-b6ae-48ed-8afb-91c725b49283', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.248Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '18.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_17_linha_19_pos_657', 'caminho_tag_fim': 'modificacao_17_linha_19_pos_666', 'conteudo': 'Quando a invenção ou melhoria resultar de contribuição específica da\n    CONTRATADA, mas, que para tanto, forem utilizados recursos, dados,\n    meios, materiais, instalações ou equipamentos da CONTRATANTE, a\n    propriedade dessa invenção ou melhoria pertencerá exclusivamente à\n    CONTRATANTE.', 'posicao_inicio_texto': 133866, 'posicao_fim_texto': 134169, 'clausulas': [{'id': 'a3d7af61-7e38-4abc-ae51-9d2421374f1c', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T03:13:42.712Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.289Z', 'conteudo': 'Quando a invenção ou melhoria resultar de contribuição específica da CONTRATADA, mas, que para tanto, forem utilizados recursos, dados, meios, materiais, instalações ou equipamentos da CONTRATANTE, a propriedade dessa invenção ou melhoria pertencerá exclusivamente à CONTRATANTE.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '18.2', 'objetivo': 'Assegurar que, mesmo que a contratada tenha contribuído para uma criação ou melhoria, se ela usou recursos da contratante para isso, o resultado final será de propriedade exclusiva da contratante.', 'nome': 'Cláusula 18ª - 18.2', 'tag': '739033a9-b6ae-48ed-8afb-91c725b49283', 'referencias': ['503e4f21-5151-429a-88ac-09c194a3cfdc', '9558632c-ca72-4e85-ab19-fa5d8748f38d', '9b843aa9-e3d6-49f7-b563-f68bbcc25f3a', 'c1abfb0e-4e6b-4af0-9737-185ed585912a']}]}, {'id': '25e2f880-f1bf-4fd7-bf67-43b36fa32ab8', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.347Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '25.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_24_linha_19_pos_676', 'caminho_tag_fim': 'modificacao_24_linha_19_pos_685', 'conteudo': 'O CONTRATO é aceito pelas PARTES como completo e suficiente para\n    definir o objeto dos Serviços, assim como sua extensão e intenção,\n    dentro das leis e normas específicas vigentes no Brasil.', 'posicao_inicio_texto': 159024, 'posicao_fim_texto': 159228, 'clausulas': [{'id': '95722a57-8196-40b9-88d7-2ac3bdfc1d03', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T10:19:49.311Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.355Z', 'conteudo': 'O CONTRATO é aceito pelas PARTES como completo e suficiente para definir o objeto dos Serviços, assim como sua extensão e intenção, dentro das leis e normas específicas vigentes no Brasil.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '25.2', 'objetivo': 'Estabelecer que o CONTRATO é completo e suficiente para definir claramente os serviços contratados, conforme as leis e normas brasileiras aplicáveis.', 'nome': 'Cláusula 25ª - 25.2', 'tag': '25e2f880-f1bf-4fd7-bf67-43b36fa32ab8', 'referencias': []}]}, {'id': '3a7d57e3-7749-4170-b55e-e97511ad3913', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.392Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '15.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_9_linha_19_pos_687', 'caminho_tag_fim': 'modificacao_9_linha_19_pos_696', 'conteudo': 'O acesso às informações confidenciais será restrito aos Funcionários\n    das PARTES que tiverem comprovada necessidade de conhecê-la, apenas\n    na extensão necessária, e deverão assinar o modelo contido no anexo\n    denominado “Termo de Confidencialidade”, que deve ser entregue aos\n    cuidados do Gestor do Contrato da CONTRATANTE.', 'posicao_inicio_texto': 121680, 'posicao_fim_texto': 122022, 'clausulas': [{'id': '9f045cd2-d59e-4beb-bfbc-bda62e9efdfa', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T02:55:26.949Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.398Z', 'conteudo': 'Limitar o acesso às informações confidenciais apenas aos funcionários que realmente precisarem delas para executar o contrato, exigindo que assinem um termo de confidencialidade específico e o entreguem ao gestor do contrato da contratante.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '15.2', 'objetivo': 'Limitar o acesso às informações confidenciais apenas aos funcionários que realmente precisarem delas para executar o contrato, exigindo que assinem um termo de confidencialidade específico e o entreguem ao gestor do contrato da contratante.', 'nome': 'Cláusula 15ª - 15.2', 'tag': '3a7d57e3-7749-4170-b55e-e97511ad3913', 'referencias': ['5a8bbb87-f8aa-419a-b726-99367dd98b8a', '69f4f1bb-3dd8-4521-9fcc-e0de1a3043e5', '993e1eb7-83d3-453a-885d-ccf60280a224']}]}, {'id': '84b28d8f-bd40-449a-90b4-bd1f83bbbbcb', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.456Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '3.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_2_linha_21_pos_693', 'caminho_tag_fim': 'modificacao_2_linha_21_pos_701', 'conteudo': 'Caso o dia do pagamento devido pela CONTRATANTE se dê em feriados\n    bancários ou em finais de semana, será considerado como data de\n    vencimento o primeiro dia útil subsequente.', 'posicao_inicio_texto': 69309, 'posicao_fim_texto': 69498, 'clausulas': [{'id': '25e2d0f6-bd0a-4b1c-b9f0-0e19b9230a1f', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-07T23:08:14.298Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.482Z', 'conteudo': 'Caso o dia do pagamento devido pela CONTRATANTE se dê em feriados bancários ou em finais de semana, será considerado como data de vencimento o primeiro dia útil subsequente.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '3.2', 'objetivo': 'Estabelecer que, se o pagamento cair em feriado ou fim de semana, o vencimento será no próximo dia útil.', 'nome': 'Cláusula 3ª - 3.2', 'tag': '84b28d8f-bd40-449a-90b4-bd1f83bbbbcb', 'referencias': ['17c8f5bc-b412-424f-aaeb-1c6dfe6bf63f', '387a7930-492b-4b3c-abef-03d1cce66af9', '507435c2-821f-4436-983a-0f3e0f93c99c', '787472e5-476f-41c6-bd4d-8d8bcce4a9f2']}]}, {'id': 'e6a86c06-e4a3-4664-9738-ab3d7979557b', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.623Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '2.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_1_linha_21_pos_696', 'caminho_tag_fim': 'modificacao_1_linha_21_pos_704', 'conteudo': 'Se aplicável, a retroatividade dos efeitos do CONTRATO, não\n    ocasionará qualquer prejuízo das obrigações da CONTRATADA sem\n    acarretar quaisquer penalidades, compensação ou lucros cessantes\n    para a CONTRATANTE, conforme prazo descrito no QUADRO RESUMO.', 'posicao_inicio_texto': 67204, 'posicao_fim_texto': 67472, 'clausulas': [{'id': '7644e09c-be7e-4de8-be0a-f233ad64d84e', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-07T22:57:54.293Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:39.636Z', 'conteudo': 'Se aplicável, a retroatividade dos efeitos do CONTRATO não ocasionará qualquer prejuízo das obrigações da CONTRATADA sem acarretar quaisquer penalidades, compensação ou lucros cessantes para a CONTRATANTE, conforme prazo descrito no QUADRO RESUMO.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '2.2', 'objetivo': 'Permitir que os efeitos do contrato sejam aplicados retroativamente, sem gerar ônus, penalidades ou compensações à CONTRATANTE.', 'nome': 'Cláusula 2ª - 2.2', 'tag': 'e6a86c06-e4a3-4664-9738-ab3d7979557b', 'referencias': ['49248bfb-93db-4468-9c1e-b1a867d94e8a', '4c394a08-9c85-476b-863e-db5e9f5e347b', '9bce2471-eb7b-437e-8928-15006cf50db3', 'ba6dc1e0-ad99-442a-a220-917ca8d2489f']}]}, {'id': 'c3e35950-f38d-4e3c-8bd8-f1c8bd0eddc7', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.797Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '24.3', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_23_linha_26_pos_728', 'caminho_tag_fim': 'modificacao_23_linha_26_pos_737', 'conteudo': 'Para os fins da arbitragem, as PARTES ajustam, desde logo, o\n    seguinte:', 'posicao_inicio_texto': 153660, 'posicao_fim_texto': 153742, 'clausulas': []}, {'id': '8463d78b-8d6b-47c3-a901-5c748bfc7d34', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:39.989Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '19.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_18_linha_20_pos_744', 'caminho_tag_fim': 'modificacao_18_linha_20_pos_753', 'conteudo': 'Caso os Serviços sejam prestados no município de Anchieta/ES, a\n    CONTRATADA se obriga a cumprir o disposto na legislação municipal\n    vigente (Lei 1.297/18 e/ou legislações que a sucederem), de forma a\n    manter o percentual mínimo exigido pela legislação para a\n    contratação de empregados locais.', 'posicao_inicio_texto': 136215, 'posicao_fim_texto': 136528, 'clausulas': [{'id': 'dd60b218-3ab1-4b5d-9e46-75da7036734d', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T03:14:53.530Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:40.049Z', 'conteudo': 'Caso os Serviços sejam prestados no município de Anchieta/ES, a CONTRATADA se obriga a cumprir o disposto na legislação municipal vigente (Lei 1.297/18 e/ou legislações que a sucederem), de forma a manter o percentual mínimo exigido pela legislação para a contratação de empregados locais.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '19.2', 'objetivo': 'Garantir que, se os serviços forem prestados em Anchieta/ES, a contratada siga a lei local, contratando a quantidade mínima obrigatória de trabalhadores do próprio município.', 'nome': 'Cláusula 19ª - 19.2', 'tag': '8463d78b-8d6b-47c3-a901-5c748bfc7d34', 'referencias': ['52a695a6-6c92-4581-ab0c-22296437c792', '9f3b664f-66f4-44e7-a908-fb91be4c19be']}]}, {'id': '86299bde-60bc-4ffb-8f53-985302219b30', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:40.132Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '10.7.2.1', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_5_linha_20_pos_746', 'caminho_tag_fim': 'modificacao_5_linha_20_pos_759', 'conteudo': 'Após o envio de comunicação as PARTES deverão se reunir para avaliar\n    uma solução conjunta para os problemas e evitar qualquer impacto à\n    prestação dos Serviços.', 'posicao_inicio_texto': 102956, 'posicao_fim_texto': 103131, 'clausulas': []}, {'id': 'd48b75e0-2e79-4f78-8113-76499bd6b9e2', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:40.159Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '16.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_10_linha_20_pos_759', 'caminho_tag_fim': 'modificacao_10_linha_20_pos_768', 'conteudo': 'Ante a ocorrência de qualquer circunstância que puder ser invocada\n    como caso fortuito ou força maior, a PARTE afetada enviará à outra,\n    no prazo de até 24 horas, após ter tomado conhecimento, uma\n    notificação, por escrito, por meio da qual comunicará a ocorrência\n    do fato, as medidas que estiverem sendo tomadas e a previsão para\n    regularização da situação.', 'posicao_inicio_texto': 124694, 'posicao_fim_texto': 125076, 'clausulas': [{'id': '802057b6-5411-4a40-b37c-1e384e2de600', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T02:59:50.051Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:40.172Z', 'conteudo': 'Garantir que, se algo imprevisível acontecer e impedir o cumprimento do contrato, a parte afetada avise a outra por escrito em até 24 horas, explicando o que aconteceu, o que está sendo feito e quando espera resolver o problema.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '16.2', 'objetivo': 'Garantir que, se algo imprevisível acontecer e impedir o cumprimento do contrato, a parte afetada avise a outra por escrito em até 24 horas, explicando o que aconteceu, o que está sendo feito e quando espera resolver o problema.', 'nome': 'Cláusula 16ª - 16.2', 'tag': 'd48b75e0-2e79-4f78-8113-76499bd6b92026-05-20T18:31:43.417608973Z e2', 'referencias': ['299eb8b4-f4a4-4ed3-ae8a-43b812628451', '991bfef5-530a-4ffa-8887-27fb91023d53', 'b8ca260a-c43c-48e5-a371-cb0c5d835273', 'f5499ba5-52bd-4c0a-b7ce-244929542bd0']}]}, {'id': '4063a51b-867d-4ae3-9e58-6ebfc84ec328', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:40.248Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '20.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_19_linha_20_pos_764', 'caminho_tag_fim': 'modificacao_19_linha_20_pos_773', 'conteudo': 'A CONTRATADA se obriga a apurar, com diligência, qualidade,\n    efetividade e dentro do prazo solicitado, todas as denúncias\n    encaminhadas pela SAMARCO que digam respeito exclusivamente à sua\n    conduta, de seus empregados e representantes, devendo, caso\n    constatada procedência, apresentar à SAMARCO plano de ação\n    específico com medidas corretivas e mitigadoras, contendo prazos\n    definidos para sua execução e comprovação de sua efetividade.', 'posicao_inicio_texto': 136854, 'posicao_fim_texto': 137319, 'clausulas': [{'id': '60f4d4e9-3cec-403b-a8cf-d13de860c014', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T03:15:24.729Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:40.264Z', 'conteudo': 'A CONTRATADA declara e garante que seus Funcionários que atuam nos negócios relacionados ao CONTRATO que envolvam direta ou indiretamente a CONTRATANTE, não violaram e não violarão a legislação anticorrupção na execução deste CONTRATO.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '20.2', 'objetivo': 'Afirmar que os funcionários da contratada, envolvidos nas atividades do contrato, não descumpriram nem descumprirão leis anticorrupção durante a execução dos serviços.', 'nome': 'Cláusula 20ª - 20.2', 'tag': '4063a51b-867d-4ae3-9e58-6ebfc84ec328', 'referencias': ['3190f78b-1f7c-437f-bdf1-cfc2e716b2a4', 'fc602006-152a-40c5-8ad0-bcb74b6fc7e6']}]}, {'id': '2f074b04-0c22-4e30-bccc-ae034464c726', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:40.307Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '23.2.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_22_linha_30_pos_778', 'caminho_tag_fim': 'modificacao_22_linha_30_pos_789', 'conteudo': 'Uma das PARTES tiver sua falência decretada.', 'posicao_inicio_texto': 145394, 'posicao_fim_texto': 145446, 'clausulas': [{'id': 'c21b4d3f-9627-4d26-a01d-733f271a3812', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T08:03:26.986Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:40.320Z', 'conteudo': 'Uma das PARTES tiver sua falência decretada.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '23.2.2', 'objetivo': 'Permitir a rescisão imediata do contrato se uma das partes tiver sua falência decretada, protegendo a outra parte de continuar a relação contratual com uma parte insolvente.', 'nome': 'Cláusula 23ª - 23.2.2', 'tag': '2f074b04-0c22-4e30-bccc-ae034464c726', 'referencias': ['0e52cd42-fe30-4837-a2c4-d16d3faa7891', '2ec5dfb0-d3f0-4f0f-bcec-a1153fd5a1a9', '453728e8-26f7-4f30-a8ae-e6d61501504b', 'd859bec4-6012-45bd-91ee-840967fb3185']}]}, {'id': 'd8cdc1a5-c51d-4b34-a8b7-2da507f0e088', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:40.839Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '12.6.1', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_6_linha_33_pos_789', 'caminho_tag_fim': 'modificacao_6_linha_33_pos_800', 'conteudo': 'Sustar o pagamento de quaisquer notas fiscais/faturas da CONTRATADA,\n    no caso de inobservância de disposição contida neste CONTRATO, até a\n    regularização da situação. Tal procedimento será comunicado por\n    escrito à CONTRATADA, sem perda do direito de aplicação das demais\n    sanções previstas neste CONTRATO.', 'posicao_inicio_texto': 115277, 'posicao_fim_texto': 115603, 'clausulas': [{'id': 'd2b912f5-a548-41cd-9b62-eb0743f0f8f8', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T02:46:44.708Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:40.942Z', 'conteudo': 'Sustar o pagamento de quaisquer notas fiscais/faturas da CONTRATADA, no caso de inobservância de disposição contida neste CONTRATO, até a regularização da situação. Tal procedimento será comunicado por escrito à CONTRATADA, sem perda do direito de aplicação das demais sanções previstas neste CONTRATO.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '12.6.1', 'objetivo': 'Definir atribuições do gestor do Contrato', 'nome': 'Cláusula 12ª - 12.6.1', 'tag': 'd8cdc1a5-c51d-4b34-a8b7-2da507f0e088', 'referencias': []}]}, {'id': '2b2bce96-4442-4010-ae63-8e8da818db5c', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:41.093Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '1.3', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_0_linha_26_pos_794', 'caminho_tag_fim': 'modificacao_0_linha_26_pos_802', 'conteudo': 'Os ANEXOS “Documentos Contratuais Gerais” ficam dispensados de\n    rubrica ou validação digital posterior. A CONTRATADA declara que já\n    recebeu estes ANEXOS previamente em mídia eletrônica ou outra forma\n    de acesso, que tem ciência do seu conteúdo e que concorda com os\n    termos neles contidos, comprometendo-se a cumpri-los na sua\n    integralidade.', 'posicao_inicio_texto': 64483, 'posicao_fim_texto': 64849, 'clausulas': [{'id': '6b61041c-62b5-4a98-9cf4-8ece29a05f1a', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-07T22:52:30.828Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:41.103Z', 'conteudo': "Os ANEXOS 'Documentos Contratuais Gerais' ficam dispensados de rubrica ou validação digital posterior. A CONTRATADA declara que já recebeu estes ANEXOS previamente em mídia eletrônica ou outra forma de acesso, que tem ciência do seu conteúdo e que concorda com os termos neles contidos, comprometendo-se a cumpri-los na sua integralidade.", 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '1.3', 'objetivo': 'Confirmar que a CONTRATADA já recebeu, leu e concorda com os anexos contratuais, mesmo sem assinatura ou validação posterior.', 'nome': 'Cláusula 1ª - 1.3', 'tag': '2b2bce96-4442-4010-ae63-8e8da818db5c', 'referencias': ['6f3e4c81-3d0b-4d4b-9285-d17b003f8871', '874c90c4-4df4-487b-a28a-3146f24d34e6', 'f8444ebd-ca35-483c-b4e1-9a8e8fb1a207', 'fd934619-7394-4fda-ae3c-51274854c5d3']}]}, {'id': 'e964c75b-272b-4805-8f48-8df6402eae57', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:41.262Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '17.2', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_11_linha_26_pos_808', 'caminho_tag_fim': 'modificacao_11_linha_26_pos_817', 'conteudo': 'Se o referido descumprimento de norma e/ou obrigação pela CONTRATADA\n    for considerado insanável pela CONTRATANTE, esta poderá aplicar\n    penalidades independente de prazo, apenas mediante envio de\n    notificação para a CONTRATADA.', 'posicao_inicio_texto': 127678, 'posicao_fim_texto': 127921, 'clausulas': [{'id': '62f8bebb-513e-4280-8d1e-edcad1075cf6', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T03:12:30.595Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:41.276Z', 'conteudo': 'Se o referido descumprimento de norma e/ou obrigação pela CONTRATADA for considerado insanável pela CONTRATANTE, esta poderá aplicar penalidades independente de prazo, apenas mediante envio de notificação para a CONTRATADA.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '17.2', 'objetivo': 'Autoriza a aplicação imediata de penalidades para falhas consideradas insanáveis, sem necessidade de prazo para correção.', 'nome': 'Cláusula 17ª - 17.2', 'tag': 'e964c75b-272b-4805-8f48-8df6402eae57', 'referencias': ['298a6ffe-1433-4545-8421-392b76abb805', 'a13f9738-ee30-4f9b-a807-cd11753fa3c5', 'af8786a4-74fb-447e-8af1-69fceecb974a', 'b0cf7300-53ad-42bb-b3ce-4b0d9c898cae', 'f2f9b57a-d483-4475-89de-a7056ec54fe5', 'f7074ff6-cc3e-42f6-b1e5-5d5fdb8e5101']}]}, {'id': 'ff034b57-fb97-4a50-b5e6-40b1eb462852', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:41.323Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '4.1.1', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_3_linha_24_pos_847', 'caminho_tag_fim': 'modificacao_3_linha_24_pos_857', 'conteudo': 'Caso o reajuste seja solicitado em prazo superior a 90 (noventa)\n    dias após a data-base, os preços reajustados somente serão aplicados\n    aos serviços/fornecimentos realizados após a data de solicitação do\n    reajuste, não retroagindo aos serviços/fornecimentos realizados\n    anteriormente.', 'posicao_inicio_texto': 71346, 'posicao_fim_texto': 71650, 'clausulas': []}, {'id': 'eb36922f-8ac2-4773-aafb-c216db998cee', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:41.335Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '22.1', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_21_linha_17_pos_878', 'caminho_tag_fim': 'modificacao_21_linha_17_pos_887', 'conteudo': 'As PARTES, ao tratarem dados pessoais no contexto de execução do\n    CONTRATO, ainda que de maneira pontual, observarão o disposto nas\n    leis de proteção de dados aplicáveis, incluindo, sem limitação, a\n    Lei nº 13.709, de 14 de agosto de 2018 (“LGPD”), em especial\n    lastrearão tratamentos de dados em base legal e em observância aos\n    princípios da LGPD. Fica também ajustado entre as PARTES que\n    tratarão tais dados pessoais na medida do necessário para atingir a\n    finalidade para qual eles foram fornecidos, para cumprimento das\n    obrigações e prerrogativas previstas no CONTRATO e eventuais\n    obrigações legais ou regulatórias, e em conformidade com as\n    Políticas de Proteção de Dados e demais orientações da CONTRATANTE,\n    obrigando-se a estender tais obrigações e conscientizar todos\n    aqueles que engajar na cadeia de tratamento.', 'posicao_inicio_texto': 142707, 'posicao_fim_texto': 143577, 'clausulas': [{'id': '82fdf602-7bdc-496e-b7e7-76b5f88d1904', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T03:18:44.111Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:41.352Z', 'conteudo': 'As PARTES, ao tratarem dados pessoais no contexto de execução do CONTRATO, ainda que de maneira pontual, observarão o disposto nas leis de proteção de dados aplicáveis, incluindo, sem limitação, a Lei nº 13.709, de 14 de agosto de 2018 ("LGPD"), em especial lastrearão tratamentos de dados em base legal e em observância aos princípios da LGPD. Fica também ajustado entre as PARTES que tratarão tais dados pessoais na medida do necessário para atingir a finalidade para qual eles foram fornecidos, para cumprimento das obrigações e prerrogativas previstas no CONTRATO e eventuais obrigações legais ou regulatórias, e em conformidade com as Políticas de Proteção de Dados e demais orientações da CONTRATANTE, obrigando-se a estender tais obrigações e conscientizar todos aqueles que engajar na cadeia de tratamento.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '22.1', 'objetivo': 'Garantir que ambas as partes tratem dados pessoais conforme a LGPD e demais leis aplicáveis, limitando o uso ao necessário, e sigam as políticas de proteção de dados da CONTRATANTE, estendendo essas obrigações a todos os envolvidos.', 'nome': 'Cláusula 22ª - 22.1', 'tag': 'eb36922f-8ac2-4773-aafb-c216db998cee', 'referencias': ['5edfcfe3-f957-4025-b3a1-594c29bfa8a2', 'e8bbc852-07d4-4f2b-a94f-abcb4cd28470']}]}, {'id': '93a74f6c-8053-4b63-9e1e-59c0876afbf1', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:41.415Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '5.1.1', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_4_linha_24_pos_893', 'caminho_tag_fim': 'modificacao_4_linha_24_pos_903', 'conteudo': 'A CONTRATADA declara estar ciente de que, no momento do pagamento, a\n    CONTRATANTE observará a legislação vigente referente à retenção do\n    Imposto Sobre Serviços de Qualquer Natureza (ISSQN), do Imposto\n    sobre a Renda (IR), da Contribuição Social sobre o Lucro Líquido\n    (CSLL), da Contribuição para o Programa de Integração Social (PIS) e\n    da Contribuição para o Financiamento da Seguridade Social (COFINS),\n    sendo que, na medida de sua aplicabilidade, procederá à retenção dos\n    aludidos tributos.', 'posicao_inicio_texto': 73495, 'posicao_fim_texto': 74020, 'clausulas': [{'id': '9d659549-cf27-4a7d-9674-02421e233388', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-07T23:14:46.480Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:41.423Z', 'conteudo': 'A CONTRATADA declara estar ciente de que, no momento do pagamento, a CONTRATANTE observará a legislação vigente referente à retenção do Imposto Sobre Serviços de Qualquer Natureza (ISSQN), do Imposto sobre a Renda (IR), da Contribuição Social sobre o Lucro Líquido (CSLL), da Contribuição para o Programa de Integração Social (PIS) e da Contribuição para o Financiamento da Seguridade Social (COFINS), sendo que, na medida de sua aplicabilidade, procederá à retenção dos aludidos tributos após a data de solicitação do reajuste, não retroagindo aos serviços/fornecimentos realizados anteriormente.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '5.1.1', 'objetivo': 'Informar que a CONTRATANTE fará as retenções tributárias exigidas por lei no momento do pagamento, conforme a legislação aplicável.', 'nome': 'Cláusula 5ª - 5.1.1', 'tag': '93a74f6c-8053-4b63-9e1e-59c0876afbf1', 'referencias': ['10c33012-b64f-45fc-9dfd-082d01d4cc63', '6729e76e-3381-4b08-83db-08998d19cc8b', '7bcef811-f33c-4248-9e2a-ef146080b610']}]}, {'id': '78cadfbb-df30-438d-9b82-4351945eacb6', 'status': 'published', 'sort': None, 'user_created': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_created': '2025-10-20T14:08:41.469Z', 'user_updated': None, 'date_updated': None, 'tag_nome': '25.3', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'caminho_tag_inicio': 'modificacao_24_linha_27_pos_907', 'caminho_tag_fim': 'modificacao_24_linha_27_pos_916', 'conteudo': 'A CONTRATANTE reserva-se o direito de auditar qualquer das etapas do\n    objeto do CONTRATO, a qualquer tempo, desde que no horário normal de\n    trabalho da CONTRATADA e de seus subcontratados aprovados.', 'posicao_inicio_texto': 159247, 'posicao_fim_texto': 159459, 'clausulas': [{'id': 'e6565e62-78f1-4e14-a67a-85995f7016ad', 'status': 'draft', 'user_created': '14d73452-5bb8-43a0-a33e-3325c2a17c1a', 'date_created': '2025-10-08T10:19:49.345Z', 'user_updated': 'ef873c96-e456-44fa-b3b4-b87a10fb7bf4', 'date_updated': '2025-10-20T14:08:41.480Z', 'conteudo': 'A CONTRATANTE reserva-se o direito de auditar qualquer das etap2026-05-20T18:31:43.417608973Z as do objeto do CONTRATO, a qualquer tempo, desde que no horário normal de trabalho da CONTRATADA e de seus subcontratados aprovados.', 'modelo_contrato': '48b43d38-76b4-47a2-93a4-4216ad57defc', 'numero': '25.3', 'objetivo': 'Garantir à CONTRATANTE o direito de auditar, a qualquer momento e durante o horário de trabalho, qualquer etapa da execução do contrato, inclusive envolvendo subcontratados.', 'nome': 'Cláusula 25ª - 25.3', 'tag': '78cadfbb-df30-438d-9b82-4351945eacb6', 'referencias': ['3576a9c8-23ec-4dc2-97f1-856c86118cb8', '5e7386e0-ab25-4de7-bbd7-a52cf9cca45e', '8bfe3389-06d8-4e7a-9643-2ef4b5a84c83', 'dab6ac2e-99f6-4c5a-a95f-79c9fa9b7b97']}]}, {'id': 