# Dockerfile para executar testes E2E
FROM python:3.13-slim

WORKDIR /app

# Instalar dependências do sistema
RUN apt-get update && apt-get install -y \
    --no-install-recommends \
    curl \
    pandoc \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Instalar UV
RUN pip install --no-cache-dir uv

# Copiar arquivos de configuração do projeto
COPY pyproject.toml uv.lock* ./

# Instalar dependências com UV (incluindo dev)
RUN uv sync

# Copiar código source
COPY versiona-ai/ ./versiona-ai/

# Copiar código de teste
COPY tests/ ./tests/
COPY .env.e2e ./

# Criar diretório para resultados
RUN mkdir -p /app/test-results

# Definir variáveis de ambiente
ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Comando padrão: executar testes E2E
CMD ["uv", "run", "pytest", "tests/e2e/", "-v", "-s"]
